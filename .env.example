# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── LLM ─────────────────────────────────────────────────────────────────────
# Model to use for Q&A and tool-use (any OpenAI-compatible model ID)
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b

# Custom system prompt for Q&A (optional)
# SYSTEM_PROMPT=You are a helpful assistant...

# ── NemoClaw (/agent command) ────────────────────────────────────────────────
NEMOCLAW_SANDBOX=my-assistant
# Path to nemoclaw.js — default: ~/.nemoclaw/source/bin/nemoclaw.js
# NEMOCLAW_BIN=/path/to/.nemoclaw/source/bin/nemoclaw.js

# ── Plugin: system ───────────────────────────────────────────────────────────
# Comma-separated jobs to monitor in /status: Label:pgrep_pattern,...
# GROUNDSTATION_JOBS=Photo export:osxphotos,Ollama:ollama serve,My job:myprocess

# ── Plugin: photos ───────────────────────────────────────────────────────────
# Destination directory for photo export
# LACIE_PHOTOS=/Volumes/LaCie/photos icloud
# Expected total number of photos
# PHOTO_EXPORT_TOTAL=0
# Path to osxphotos binary (default: osxphotos from PATH)
# OSXPHOTOS_BIN=/home/user/.local/bin/osxphotos
# Override the full export command (optional)
# PHOTO_EXPORT_CMD=bash /path/to/resume_photo_export.command

# ── Plugin: ollama ───────────────────────────────────────────────────────────
# Where Ollama stores models (default: ~/.ollama/models)
# OLLAMA_MODELS_PATH=~/.ollama/models

# ── Plugin: zotero ───────────────────────────────────────────────────────────
# Directory where analysis results are written
# ZOTERO_RESULTS_DIR=~/zotero_analysis_results
# Command to run the analysis script
# ZOTERO_ANALYSIS_CMD=python3 ~/zotero_analysis.py

# ── LaunchAgent (Mac only) ───────────────────────────────────────────────────
# Label for the launchd service (default: com.groundstation.bot)
# GROUNDSTATION_LABEL=com.groundstation.bot
