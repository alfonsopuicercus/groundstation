# Copy this to .env and fill in your values. Never commit .env to git.

TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# Paths (adjust if different on your machine)
LACIE_PHOTOS=/Volumes/LaCie/photos icloud
LACIE_ROOT=/Volumes/LaCie
OLLAMA_MODELS_PATH=/Volumes/LaCie/ollama-models
PHOTO_EXPORT_TOTAL=19132

# NemoClaw sandbox name
NEMOCLAW_SANDBOX=my-assistant
